          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();\r",
                  "\r",
                  "// Save dynamic ID (for demonstration)\r",
                  "pm.environment.set(\"dynamicUserId\", res.id);\r",
                  "\r",
                  "// Save valid static ID (IMPORTANT FIX)\r",
                  "pm.environment.set(\"validUserId\", 1);\r",
                  "\r",
                  "pm.test(\"User created\", function () {\r",
                  "    pm.expect(res.id).to.exist;\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
