        {
          "name": "Fetch User Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();\r",
                  "\r",
                  "pm.test(\"User fetched correctly\", function () {\r",
                  "    pm.expect(res.id).to.eql(1);\r",
                  "});\r",
                  "\r",
                  "// Schema validation\r",
                  "var schema = {\r",
                  "    type: \"object\",\r",
                  "    properties: {\r",
                  "        id: { type: \"number\" },\r",
                  "        firstName: { type: \"string\" },\r",
                  "        lastName: { type: \"string\" },\r",
                  "        age: { type: \"number\" }\r",
                  "    },\r",
                  "    required: [\"id\", \"firstName\", \"lastName\"]\r",
                  "};\r",
                  "\r",
                  "pm.test(\"Schema valid\", function () {\r",
                  "    pm.expect(tv4.validate(res, schema)).to.be.true;\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
